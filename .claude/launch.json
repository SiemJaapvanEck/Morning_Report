{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 3000
    },
    {
      "name": "start",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start", "--", "--port", "3001"],
      "port": 3001
    }
  ],
  "experimentalServices": {
    "app": {
      "root": ".",
      "routePrefix": "/",
      "framework": "nextjs"
    }
  }
}
