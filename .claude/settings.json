{
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Bash(npm run lint && npx tsc --noEmit && npm test && npm run build)",
      "Bash(git:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(find:*)",
      "Bash(rm:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(grep:*)",
      "Bash(echo:*)",
      "Bash(test:*)",
      "Bash(date:*)",
      "Bash(cd:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(wc:*)",
      "Bash(touch:*)",
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep"
    ],
    "deny": [
      "mcp__85c1d460-2593-4162-ba82-46384dbcfc10__execute_sql",
      "mcp__85c1d460-2593-4162-ba82-46384dbcfc10__deploy_edge_function",
      "mcp__85c1d460-2593-4162-ba82-46384dbcfc10__merge_branch",
      "mcp__85c1d460-2593-4162-ba82-46384dbcfc10__reset_branch"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/guard-push-main.sh\""
          }
        ]
      }
    ]
  }
}
